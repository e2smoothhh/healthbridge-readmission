# ── Data files — never commit raw patient data ────────────────────────────────
data/raw/
data/processed/
*.csv
*.xlsx
*.xls

# Exception — keep placeholder files and documentation
!data/DATA_SOURCES.md
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Model artifacts (can be large) ────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
# Exception — keep model notes
!models/MODEL_NOTES.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Jupyter Notebook checkpoints ──────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env
.venv
ENV/

# ── IDE and OS files ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ── Colab-specific ────────────────────────────────────────────────────────────
*.colab

# ── Sensitive / credentials ───────────────────────────────────────────────────
*.key
*.pem
secrets.py
config.py
.env.*
